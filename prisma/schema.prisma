// =============================================================================
// "字见" AI驱动聋哑人识字辅助系统 — Prisma Schema
// =============================================================================
// 数据库: PostgreSQL 16 (Supabase)
// ORM:    Prisma 5
// 架构参考: docs/arch/Evolved_ARCH.md § 6. 数据库设计
// 任务:    TASK-DB-001
// 日期:    2026-03-13
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// =============================================================================
// 枚举类型
// =============================================================================

/// 用户角色（RBAC 权限控制核心）
/// - child:    儿童用户，受严格限制（每日限20次生成、夜间禁用、须绑定监护人）
/// - adult:    成人用户，默认角色
/// - guardian: 监护人，可查看被监护儿童的学习记录
/// - teacher:  教师，可查看班级学习报告
/// - admin:    管理员，可进行内容审核管理
enum Role {
  child
  adult
  guardian
  teacher
  admin
}

/// 用户账号状态
enum UserStatus {
  active   // 正常使用
  inactive // 已停用（用户主动注销）
  banned   // 已封禁（违规封禁）
}

/// 可视化内容类型
enum ContentType {
  image // 静态图片（通义万相生成）
  video // 短视频（可灵 AI 生成）
}

/// 内容审核状态（三级审核流水线）
/// 所有内容必须为 approved 后方可对用户展示（安全生命线，绝不降级）
enum ReviewStatus {
  pending  // 待审核（刚生成，未经审核）
  approved // 已通过（可对用户展示）
  rejected // 已拒绝（内容违规，不可展示）
}

// =============================================================================
// 1. profiles — 用户基础信息表
// =============================================================================

/// 用户基础信息表
/// 与 Supabase Auth 的 auth.users 通过 id（UUID）关联
/// phone_enc: 字段级加密存储（AES-256），登录时以加密值查询，避免明文落库
/// locked_until: 暴力破解防护，连续5次失败后锁定30分钟
model Profile {
  id           String     @id @default(uuid())
  phone_enc    String?    // 字段级加密存储的手机号（AES-256，明文不落库）
  nickname     String?    @db.VarChar(50)
  avatar_url   String?    @db.VarChar(500)
  role         Role       @default(adult)
  status       UserStatus @default(active)
  locked_until DateTime?  // 账号锁定截止时间（null = 未锁定）
  created_at   DateTime   @default(now())
  updated_at   DateTime   @updatedAt

  // 关联关系
  word_books        WordBook[]
  sessions          UserSession[]
  learning_records  LearningRecord[]
  translate_history TranslateHistory[]

  // phone_enc 查询索引（登录时根据加密手机号定位用户）
  @@index([phone_enc])
  @@map("profiles")
}

// =============================================================================
// 2. user_sessions — 用户会话表
// =============================================================================

/// 用户会话管理表
/// 追踪 JWT Token 状态，支持主动撤销（用户登出 / 管理员强制下线）
/// 安全原则：不存储明文 Token，仅存 SHA-256(token) 哈希值
model UserSession {
  id         String    @id @default(uuid())
  user_id    String
  token_hash String    @db.VarChar(64)  // JWT Token 的 SHA-256 哈希（64位十六进制）
  ip_address String?   @db.VarChar(45)  // 支持 IPv4（≤15位）和 IPv6（≤45位）
  user_agent String?   @db.VarChar(500) // 浏览器/设备标识
  created_at DateTime  @default(now())
  expires_at DateTime  // Token 自然过期时间
  revoked_at DateTime? // 主动撤销时间（null = 会话有效）

  // 关联关系
  user Profile @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([token_hash]) // Token 验证时的高频查询索引
  @@map("user_sessions")
}

// =============================================================================
// 3. word_books — 识字库表
// =============================================================================

/// 用户识字库
/// 每位用户可创建多个识字库，有且仅有一个默认库（is_default = true）
/// 注册时系统自动为每个用户创建一个默认识字库
model WordBook {
  id         String   @id @default(uuid())
  user_id    String
  name       String   @db.VarChar(100)
  is_default Boolean  @default(false)
  created_at DateTime @default(now())

  // 关联关系
  user  Profile        @relation(fields: [user_id], references: [id], onDelete: Cascade)
  items WordBookItem[]

  // user_id 索引（获取用户所有识字库列表）
  @@index([user_id])
  @@map("word_books")
}

// =============================================================================
// 4. word_book_items — 识字库条目表
// =============================================================================

/// 识字库中的汉字条目
/// 采用 SM-2 间隔重复算法管理复习计划
///
/// SM-2 字段说明:
///   mastery_level: 掌握等级 0-5（5 = 完全掌握，不再进入复习队列）
///   ease_factor:   难度因子 EF（默认 2.5，范围 1.3-2.5，越大间隔越长）
///   review_count:  累计复习次数
///   next_review_at: 下次复习时间（SM-2 算法计算，null = 尚未开始学习）
///
/// 注：PostgreSQL 部分索引（WHERE mastery_level < 5）需在迁移 SQL 中手动添加
///     见 prisma/migrations/xxx/migration.sql 中 idx_wbi_review 的创建语句
model WordBookItem {
  id             String    @id @default(uuid())
  book_id        String
  character      String    @db.VarChar(4)              // 单个汉字（含部分多字节字符，预留4字节）
  mastery_level  Int       @default(0)                 // SM-2 掌握等级 0-5
  ease_factor    Decimal   @default(2.5) @db.Decimal(4, 2) // SM-2 难度因子（保留2位小数）
  review_count   Int       @default(0)                 // 累计复习次数
  next_review_at DateTime?                             // 下次复习时间（SM-2 预计算）
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt

  // 关联关系
  book WordBook @relation(fields: [book_id], references: [id], onDelete: Cascade)

  // 复合索引：按识字库+复习时间查询待复习汉字（核心学习路径，必须极快）
  // 生产补充：在迁移 SQL 中替换为部分索引 WHERE mastery_level < 5
  @@index([book_id, next_review_at])
  // 复合索引：按识字库+掌握程度过滤（学习进度统计）
  @@index([book_id, mastery_level])
  @@map("word_book_items")
}

// =============================================================================
// 5. learning_records — 学习记录表
// =============================================================================

/// 用户学习行为记录
/// 用于进度统计、连续学习天数计算、学习报告生成（监护人/教师可查）
///
/// action_type 取值约定（应用层强约束，数据库层 VarChar 存储）:
///   master   — 首次掌握一个汉字
///   practice — 日常练习
///   review   — SM-2 间隔复习
model LearningRecord {
  id          String   @id @default(uuid())
  user_id     String
  character   String   @db.VarChar(4)   // 本次学习的汉字
  action_type String   @db.VarChar(20)  // master | practice | review
  accuracy    Int      // 本次正确率 0-100（百分比整数）
  created_at  DateTime @default(now())

  // 关联关系
  user Profile @relation(fields: [user_id], references: [id], onDelete: Cascade)

  // 覆盖索引：按用户+时间查询（高频，覆盖 character/action_type/accuracy 字段）
  // 注：完整覆盖索引（INCLUDE 子句）在迁移 SQL 中手动添加：idx_lr_user_ts
  @@index([user_id, created_at])
  @@map("learning_records")
}

// =============================================================================
// 6. translate_history — 语言转换历史表
// =============================================================================

/// 手语式文本 → 标准书面语转换历史记录
/// 聋哑用户将手语语序的文字输入转换为标准书面语
/// is_fallback: true 表示 AI 服务熔断，使用了规则引擎降级方案
model TranslateHistory {
  id          String   @id @default(uuid())
  user_id     String
  input_text  String   @db.Text          // 手语式原文（最大500字符，应用层限制）
  output_text String   @db.Text          // 书面语译文
  confidence  Decimal? @db.Decimal(4, 3) // AI 转换置信度 0.000-1.000
  ai_provider String?  @db.VarChar(50)   // 使用的 AI 服务商（通义千问/DeepSeek 等）
  is_fallback Boolean  @default(false)   // true = 使用了规则引擎降级方案
  created_at  DateTime @default(now())

  // 关联关系
  user Profile @relation(fields: [user_id], references: [id], onDelete: Cascade)

  // 复合索引：按用户+时间查询转换历史
  @@index([user_id, created_at])
  @@map("translate_history")
}

// =============================================================================
// 7. visual_contents — 可视化内容表
// =============================================================================

/// 汉字可视化内容（图片/视频）
/// 两种内容来源：
///   预生成（is_pregenerated = true）: 3500 常用字离线批量生成，user_id = NULL
///   用户生成（is_pregenerated = false）: 用户请求实时生成，user_id 非空
///
/// 安全原则：所有内容必须经三级审核（review_status = approved）才可展示给用户
/// 唯一约束防止重复生成同款内容（节约 AI API 费用）
model VisualContent {
  id              String       @id @default(uuid())
  character       String       @db.VarChar(4)   // 对应汉字
  style           String       @db.VarChar(30)  // cartoon | ink | 3d | pictographic
  content_type    ContentType
  storage_url     String       @db.VarChar(500) // Supabase Storage 的对象路径或签名 URL
  prompt_hash     String?      @db.VarChar(64)  // SHA-256(prompt)，用于去重检测
  user_id         String?                       // 预生成内容为 NULL
  is_pregenerated Boolean      @default(false)  // true = 3500常用字预生成资源
  review_status   ReviewStatus @default(pending) // 三级内容审核状态（安全生命线）
  created_at      DateTime     @default(now())

  // 唯一约束：同一汉字 + 风格 + 类型 + 预生成标记 组合唯一
  // 防止重复生成浪费 AI API 费用，同时确保资源精确命中
  @@unique([character, style, content_type, is_pregenerated])
  // 复合索引：按字符+风格+审核状态查找可用内容
  @@index([character, style, review_status])
  @@map("visual_contents")
}

// =============================================================================
// 8. object_char_mappings — 物体-汉字映射表（ESP32-S3 硬件功能）
// =============================================================================

/// 摄像头识别物体标签与汉字的映射关系
/// ESP32-S3 设备通过 YOLO 识别物体后，查此表获取对应中文汉字
/// object_label_en: YOLO 模型输出的英文标签（全局唯一，如 "cat"、"apple"）
/// 初始数据通过 prisma/seed.ts 批量导入（常见物体约200条）
model ObjectCharMapping {
  id              String   @id @default(uuid())
  object_label_en String   @unique @db.VarChar(100) // YOLO 英文标签（全局唯一映射）
  char_zh         String   @db.VarChar(10)          // 对应中文汉字
  pinyin          String?  @db.VarChar(50)           // 拼音标注（含声调，如 "māo"）
  category        String?  @db.VarChar(50)           // 物体分类（动物/植物/交通工具/食物等）
  created_at      DateTime @default(now())

  @@map("object_char_mappings")
}

// =============================================================================
// 9. object_recognition_records — 物体识别记录表（ESP32-S3 硬件功能）
// =============================================================================

/// ESP32-S3 设备物体识别历史记录
/// 记录每次摄像头识别结果，支持用户一键将识别汉字加入个人识字库
/// user_id 可为空（设备端可能处于未登录状态，支持离线使用）
model ObjectRecognitionRecord {
  id                String   @id @default(uuid())
  user_id           String?                          // 未登录设备为 NULL
  image_url         String?  @db.VarChar(500)        // 上传到 Supabase Storage 的图片路径
  label_zh          String   @db.VarChar(10)         // 识别到的中文汉字
  label_en          String?  @db.VarChar(100)        // YOLO 原始英文标签
  confidence        Decimal? @db.Decimal(5, 4)       // 识别置信度 0.0000-1.0000（4位小数）
  recognized_at     DateTime @default(now())
  saved_to_wordbook Boolean  @default(false)         // 用户是否已将此字加入识字库

  // 复合索引：按用户+识别时间查询历史记录
  @@index([user_id, recognized_at])
  @@map("object_recognition_records")
}
